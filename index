  </div>

  <div class="nav-actions">
    <div class="nav-link">
      <span>Hello, Sign In</span>
      <strong>Account & Lists ▾</strong>
    </div>
    <div class="nav-link">
      <span>Returns</span>
      <strong>& Orders</strong>
    </div>
    <div class="cart-btn nav-link" onclick="toggleCart()">
      <span class="cart-icon">🛒</span>
      <span class="cart-count" id="cartCount">3</span>
      <span class="cart-label">Cart</span>
    </div>
  </div>
</nav>

<!-- SUBNAV -->
<div class="subnav">
  <a href="#" class="active">☰ All</a>
  <a href="#">Today's Deals</a>
  <a href="#">Electronics</a>
  <a href="#">Fashion</a>
  <a href="#">Home & Kitchen</a>
  <a href="#">Books</a>
  <a href="#">Sports</a>
  <a href="#">Beauty</a>
  <a href="#">Toys</a>
  <a href="#">Automotive</a>
  <a href="#">Grocery</a>
  <a href="#">Prime ★</a>
</div>

<!-- HERO -->
<section class="hero">
  <div class="hero-content">
    <div class="hero-eyebrow">Summer Sale 2026</div>
    <h1>Shop Smarter,<br>Live Better</h1>
    <p>Millions of products, unbeatable prices, delivered to your doorstep. Free delivery on orders over ₹499.</p>
    <div class="hero-btns">
      <button class="btn-primary">Explore Deals →</button>
      <button class="btn-outline">Join Prime ★</button>
    </div>
  </div>
  <div class="hero-visual">
    <div class="hero-thumb big">📱</div>
    <div class="hero-thumb">👟</div>
    <div class="hero-thumb">🎧</div>
    <div class="hero-thumb">📚</div>
    <div class="hero-thumb">🏠</div>
  </div>
</section>

<!-- DEALS TICKER -->
<div class="deals-ticker">
  <div class="ticker-inner" id="ticker">
    <div class="ticker-item"><span>⚡</span> Up to 70% off Electronics</div>
