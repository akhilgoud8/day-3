<script>
  // ── PRODUCT DATA ──
  const products = [
    { emoji:'📱', name:'Samsung Galaxy S24 Ultra 5G 256GB Phantom Black', price:89999, original:109999, rating:4.5, reviews:12430, badge:'deal', off:18 },
    { emoji:'🎧', name:'Sony WH-1000XM5 Wireless Noise Cancelling Headphones', price:24990, original:34990, rating:4.7, reviews:8210, badge:'prime', off:29 },
    { emoji:'💻', name:'Apple MacBook Air M3 13-inch 8GB RAM 256GB SSD', price:114900, original:129900, rating:4.8, reviews:5670, badge:'new', off:12 },
    { emoji:'⌚', name:'Apple Watch Series 10 GPS 42mm Starlight Aluminium', price:39900, original:45900, rating:4.6, reviews:3890, badge:'deal', off:13 },
    { emoji:'📷', name:'Canon EOS R50 Mirrorless Camera with 18-45mm Lens Kit', price:67990, original:79995, rating:4.4, reviews:2140, badge:'', off:15 },
    { emoji:'🎮', name:'Sony PlayStation 5 Slim Digital Edition Console', price:44990, original:54990, rating:4.8, reviews:21000, badge:'deal', off:18 },
    { emoji:'🖥️', name:'LG 27GN800-B 27" UltraGear QHD 144Hz Gaming Monitor', price:22990, original:31990, rating:4.5, reviews:6780, badge:'prime', off:28 },
    { emoji:'🔊', name:'JBL Flip 6 Portable Wireless Bluetooth Speaker IPX7', price:7499, original:11999, rating:4.6, reviews:34500, badge:'deal', off:37 },
  ];

  const flashDeals = [
    { emoji:'👟', name:'Nike Air Max 270 Running Shoes', price:5999, off:'60% off', progress:72 },
    { emoji:'📺', name:'Samsung 55" 4K QLED Smart TV', price:49990, off:'45% off', progress:41 },
    { emoji:'🧴', name:'Minimalist 10% Niacinamide Serum Pack of 3', price:599, off:'55% off', progress:88 },
    { emoji:'☕', name:'Nespresso Vertuo Next Coffee Machine', price:11990, off:'35% off', progress:27 },
    { emoji:'🎒', name:'Wildcraft 55L Hiking Backpack Waterproof', price:1999, off:'50% off', progress:63 },
    { emoji:'🌡️', name:'Omron HEM-7120 Automatic Blood Pressure Monitor', price:1299, off:'42% off', progress:55 },
  ];

  const miniItems = [
    { emoji:'📖', name:'Atomic Habits by James Clear', price:399 },
    { emoji:'🍳', name:'Non-Stick Kadhai Set 3-Piece', price:1299 },
    { emoji:'👕', name:'Men\'s Cotton T-Shirt Pack of 5', price:799 },
    { emoji:'🧘', name:'Yoga Mat Anti-Slip 6mm Thick', price:699 },
    { emoji:'🔦', name:'LED Torch Rechargeable 3000mAh', price:349 },
    { emoji:'🌱', name:'Indoor Plant Combo Set of 4', price:599 },
    { emoji:'🧩', name:'Rubik\'s Speed Cube 3x3 Professional', price:449 },
    { emoji:'🎸', name:'Acoustic Guitar Beginner Pack', price:3499 },
  ];

  function stars(rating) {
    const full = Math.floor(rating), half = rating % 1 >= 0.5;
    return '★'.repeat(full) + (half ? '½' : '') + '☆'.repeat(5 - full - (half?1:0));
  }

  function renderProducts() {
    const grid = document.getElementById('productsGrid');
    grid.innerHTML = products.map(p => `
      <div class="product-card" onclick="addToCart()">
        <div class="product-img">
          ${p.emoji}
          ${p.badge ? `<span class="badge badge-${p.badge}">${p.badge === 'deal' ? '🔥 Deal' : p.badge === 'new' ? '✨ New' : '⭐ Prime'}</span>` : ''}
        </div>
        <div class="product-body">
          <div class="product-name">${p.name}</div>
          <div class="stars">
            <span>${stars(p.rating)}</span>
            <span class="review-count">(${p.reviews.toLocaleString('en-IN')})</span>
          </div>
          <div class="price-row">
            <span class="price">₹${p.price.toLocaleString('en-IN')}</span>
            <span class="price-original">₹${p.original.toLocaleString('en-IN')}</span>
            <span class="discount-pct">${p.off}% off</span>
          </div>
          <button class="add-btn">Add to Cart 🛒</button>
        </div>
      </div>
    `).join('');
  }

  function renderDeals() {
    const grid = document.getElementById('dealsGrid');
    grid.innerHTML = flashDeals.map(d => `
      <div class="deal-card">
        <div class="deal-img">${d.emoji}<span class="badge badge-deal" style="top:8px;left:8px">${d.off}</span></div>
        <div class="deal-body">
          <div class="deal-name">${d.name}</div>
          <div class="deal-price">₹${d.price.toLocaleString('en-IN')}</div>
          <div class="deal-progress">
            <div class="progress-bar"><div class="progress-fill" style="width:${d.progress}%"></div></div>
            <div class="progress-label">${d.progress}% claimed</div>
          </div>
        </div>
      </div>
    `).join('');
  }

  function renderMini() {
    const grid = document.getElementById('miniGrid');
    grid.innerHTML = miniItems.map(m => `
      <div class="mini-card">
        <div class="mini-img">${m.emoji}</div>
        <div class="mini-name">${m.name}</div>
        <div class="mini-price">₹${m.price.toLocaleString('en-IN')}</div>
      </div>
    `).join('');
  }

  // ── CART ──
  let cartCount = 3;
  function addToCart() {
    cartCount++;
    document.getElementById('cartCount').textContent = cartCount;
    const btn = event.target.closest('.product-card');
    if (btn) { btn.style.outline = '2px solid var(--amber)'; setTimeout(() => btn.style.outline = '', 600); }
  }
  function toggleCart() {
    alert(`You have ${cartCount} items in your cart.\n(Cart page would open here)`);
  }

  // ── COUNTDOWN ──
  let totalSecs = 2 * 3600 + 47 * 60 + 33;
  function tick() {
    totalSecs--;
    if (totalSecs < 0) totalSecs = 6 * 3600;
    const h = String(Math.floor(totalSecs/3600)).padStart(2,'0');
    const m = String(Math.floor((totalSecs%3600)/60)).padStart(2,'0');
    const s = String(totalSecs%60).padStart(2,'0');
    document.getElementById('countdown').textContent = `${h}:${m}:${s}`;
  }
  setInterval(tick, 1000);

  // ── SEARCH ──
  function handleSearch() {
    const q = document.getElementById('searchInput').value.trim();
    if (q) alert(`Searching for: "${q}"\n(Results page would load here)`);
  }
  document.getElementById('searchInput').addEventListener('keydown', e => { if(e.key==='Enter') handleSearch(); });

  // INIT
  renderProducts();
  renderDeals();
  renderMini();
</script>
